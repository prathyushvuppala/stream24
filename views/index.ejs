<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Stream24 | Live Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { font-family: 'Open Sans', sans-serif; }
        h1, h2, h3 { font-family: 'Segoe UI', sans-serif; }
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-thumb { background: #475569; border-radius: 4px; }
    </style>
</head>
<body class="bg-slate-900 text-gray-200 min-h-screen">

    <header class="bg-slate-800 p-6 flex justify-between items-center border-b border-slate-700 shadow-lg">
        <div>
            <h1 class="text-3xl font-bold text-white tracking-wider flex items-center gap-2">
                <span class="text-blue-500">●</span> Stream24
            </h1>
            <p class="text-xs text-slate-400 mt-1 uppercase tracking-widest">Global Intelligence</p>
        </div>
        
        <div class="text-right">
            <p class="text-2xl font-semibold text-white tracking-wide" id="clock">--:-- --</p>
        </div>
    </header>

    <nav class="bg-slate-800/50 p-4 border-b border-slate-700 flex flex-wrap gap-4 items-center justify-between px-8">
        <div class="flex gap-2 items-center">
            <button data-btn="All" onclick="filterCategory('All')" class="filter-btn px-4 py-2 bg-blue-600 text-white rounded-lg text-sm font-semibold transition">All</button>
            <button data-btn="Tech & AI" onclick="filterCategory('Tech & AI')" class="filter-btn px-4 py-2 bg-slate-700 hover:bg-slate-600 rounded-lg text-sm font-semibold transition">Tech & AI</button>
            <button data-btn="Health" onclick="filterCategory('Health')" class="filter-btn px-4 py-2 bg-slate-700 hover:bg-slate-600 rounded-lg text-sm font-semibold transition">Health</button>
            <button data-btn="Finance & Stocks" onclick="filterCategory('Finance & Stocks')" class="filter-btn px-4 py-2 bg-slate-700 hover:bg-slate-600 rounded-lg text-sm font-semibold transition">Finance & Stocks</button>
            
            <select id="sportsDropdown" onchange="filterCategory(this.value)" class="filter-btn px-4 py-2 bg-slate-700 hover:bg-slate-600 rounded-lg text-sm font-semibold transition appearance-none cursor-pointer outline-none">
                <option value="Sports">Sports (All)</option>
                <option value="Cricket">Cricket</option>
                <option value="NFL">NFL</option>
                <option value="NBA">NBA</option>
                <option value="MLB">MLB</option>
            </select>
        </div>

        <div class="flex gap-4 items-center">
            <input type="text" id="searchInput" placeholder="Search live feed..." class="px-4 py-2 bg-slate-900 border border-slate-700 rounded-lg text-sm focus:outline-none focus:border-blue-500 w-64">
            <button onclick="openSaved()" class="px-4 py-2 bg-yellow-600/20 text-yellow-500 border border-yellow-600/50 hover:bg-yellow-600/30 rounded-lg text-sm font-semibold transition flex items-center gap-2">
                <span>📌</span> Saved
            </button>
        </div>
    </nav>

    <main class="p-8 max-w-screen-2xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6" id="newsContainer">
            <% if (typeof newsItems !== 'undefined' && newsItems.length > 0) { %>
                <% newsItems.forEach(item => { %>
                    <div class="news-card bg-slate-800 p-6 rounded-xl border border-slate-700 hover:border-blue-500 transition duration-300 flex flex-col justify-between" data-category="<%= item.category %>">
                        <div>
                            <div class="flex justify-between items-start mb-3">
                                <span class="text-xs font-bold text-blue-400 uppercase tracking-wider"><%= item.category %></span>
                                <button onclick="saveArticle('<%= item.link %>', `<%= item.title.replace(/'/g, '&apos;').replace(/"/g, '&quot;') %>`, '<%= item.category %>')" class="text-slate-500 hover:text-yellow-400 transition" title="Save for later">📌</button>
                            </div>
                            <h3 class="text-lg font-bold text-white leading-tight mb-2"><%= item.title %></h3>
                            <p class="text-sm text-slate-400 line-clamp-3 mb-4"><%= item.summary %></p>
                        </div>
                        
                        <div class="flex justify-between items-center mt-4 pt-4 border-t border-slate-700">
                            <button onclick="openModal(`<%= item.title.replace(/'/g, '&apos;').replace(/"/g, '&quot;') %>`, `<%= item.summary.replace(/'/g, '&apos;').replace(/"/g, '&quot;') %>`, '<%= item.link %>')" class="text-sm text-blue-400 hover:text-blue-300 font-semibold">Read More →</button>
                        </div>
                    </div>
                <% }) %>
            <% } %>
        </div>
    </main>

    <div id="readModal" class="fixed inset-0 bg-black/80 hidden items-center justify-center z-50 p-4">
        <div class="bg-slate-800 p-8 rounded-xl max-w-2xl w-full border border-slate-700 relative shadow-2xl">
            <button onclick="closeModal()" class="absolute top-4 right-4 text-slate-400 hover:text-white text-xl font-bold">&times;</button>
            <h2 id="modalTitle" class="text-2xl font-bold text-white mb-4 pr-6"></h2>
            <div id="modalContent" class="text-slate-300 text-sm leading-relaxed mb-6 max-h-96 overflow-y-auto pr-2"></div>
            <hr class="border-slate-700 mb-6">
            <a id="modalLink" href="#" target="_blank" class="inline-block px-6 py-3 bg-blue-600 hover:bg-blue-500 text-white font-bold rounded-lg transition w-full text-center">Read Full Story at Source</a>
        </div>
    </div>

    <div id="savedModal" class="fixed inset-0 bg-black/80 hidden items-center justify-center z-50 p-4">
        <div class="bg-slate-800 p-8 rounded-xl max-w-md w-full border border-slate-700 relative shadow-2xl">
            <button onclick="closeSaved()" class="absolute top-4 right-4 text-slate-400 hover:text-white text-xl font-bold">&times;</button>
            <h2 class="text-xl font-bold text-white mb-6 pr-6">📌 Saved Articles</h2>
            
            <div id="savedList" class="flex flex-col gap-3 max-h-96 overflow-y-auto pr-2 mb-4">
                </div>

            <button onclick="clearSaved()" class="w-full px-4 py-2 bg-red-600/20 text-red-500 border border-red-600/50 hover:bg-red-600/30 rounded-lg text-sm font-semibold transition">Clear All Bookmarks</button>
        </div>
    </div>

    <script>
        // Clock
        setInterval(() => {
            document.getElementById('clock').innerText = new Date().toLocaleTimeString('en-US', {hour: '2-digit', minute:'2-digit'});
        }, 1000);

        // Filter Logic & Button Highlighting
        function filterCategory(category) {
            // 1. Reset all buttons to gray
            document.querySelectorAll('.filter-btn').forEach(btn => {
                btn.classList.remove('bg-blue-600', 'text-white');
                btn.classList.add('bg-slate-700');
            });
            
            // 2. Highlight the clicked button blue
            const activeBtn = document.querySelector(`.filter-btn[data-btn="${category}"]`);
            if(activeBtn) {
                activeBtn.classList.remove('bg-slate-700');
                activeBtn.classList.add('bg-blue-600', 'text-white');
            }

            // 3. Highlight dropdown if a sport is selected
            const dropdown = document.getElementById('sportsDropdown');
            if(['Sports', 'Cricket', 'NFL', 'NBA', 'MLB'].includes(category)) {
                 dropdown.classList.remove('bg-slate-700');
                 dropdown.classList.add('bg-blue-600', 'text-white');
            }

            // 4. Filter the actual cards
            const cards = document.querySelectorAll('.news-card');
            cards.forEach(card => {
                const cardCat = card.getAttribute('data-category');
                if (category === 'All' || cardCat === category || (category === 'Sports' && ['Cricket', 'NFL', 'NBA', 'MLB'].includes(cardCat))) {
                    card.style.display = 'flex';
                } else {
                    card.style.display = 'none';
                }
            });
        }

        // Live Search
        document.getElementById('searchInput').addEventListener('keyup', (e) => {
            const term = e.target.value.toLowerCase();
            const cards = document.querySelectorAll('.news-card');
            cards.forEach(card => {
                const text = card.innerText.toLowerCase();
                card.style.display = text.includes(term) ? 'flex' : 'none';
            });
        });

        // Modals
        function openModal(title, summary, link) {
            document.getElementById('modalTitle').innerText = title;
            document.getElementById('modalContent').innerHTML = summary || 'No summary provided by source.';
            document.getElementById('modalLink').href = link;
            document.getElementById('readModal').classList.remove('hidden');
            document.getElementById('readModal').classList.add('flex');
        }

        function closeModal() {
            document.getElementById('readModal').classList.add('hidden');
            document.getElementById('readModal').classList.remove('flex');
        }

        // Saved Articles Logic
        function saveArticle(link, title, category) {
            let saved = JSON.parse(localStorage.getItem('stream24_saved') || '[]');
            if (!saved.some(item => item.link === link)) {
                saved.push({ link, title, category });
                localStorage.setItem('stream24_saved', JSON.stringify(saved));
                alert('Article saved!');
            }
        }

        function openSaved() {
            let saved = JSON.parse(localStorage.getItem('stream24_saved') || '[]');
            const container = document.getElementById('savedList');
            container.innerHTML = '';

            if (saved.length === 0) {
                container.innerHTML = '<p class="text-slate-400 text-sm">You have not saved any articles yet.</p>';
            } else {
                saved.forEach(item => {
                    // Create clickable UI cards for the modal
                    container.innerHTML += `
                        <a href="${item.link}" target="_blank" class="block p-4 bg-slate-900 border border-slate-700 hover:border-blue-500 rounded-lg transition group">
                            <span class="text-xs text-blue-400 font-bold block mb-1 uppercase tracking-wider">${item.category}</span>
                            <span class="text-sm text-white font-semibold group-hover:text-blue-300 transition">${item.title}</span>
                        </a>
                    `;
                });
            }
            
            document.getElementById('savedModal').classList.remove('hidden');
            document.getElementById('savedModal').classList.add('flex');
        }

        function closeSaved() {
            document.getElementById('savedModal').classList.add('hidden');
            document.getElementById('savedModal').classList.remove('flex');
        }

        function clearSaved() {
            if(confirm("Delete all saved articles?")) {
                localStorage.removeItem('stream24_saved');
                openSaved(); // refresh the modal UI
            }
        }
    </script>
</body>
</html>